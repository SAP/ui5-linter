<mvc:View xmlns:mvc="sap.ui.core.mvc"
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:table="sap.ui.table"
	xmlns:tablePlugins="sap.ui.table.plugins"
	controllerName="com.myapp.controller.Main"
>
	<!-- Deprecated reference of global formatter function -->
	<ObjectStatus text="{
		path: 'invoice>Status',
		formatter: 'ui5.walkthrough.model.formatter.statusText'
	}"/>

	<!-- Correct import of formatter function -->
	<ObjectStatus
		core:require="{
			Formatter: 'ui5/walkthrough/model/formatter'
		}"
		text="{
			path: 'invoice>Status',
			formatter: 'Formatter.statusText.bind($controller)'
		}"
	/>

</mvc:View>
